{
  "name": "context-mode-post",
  "version": "1.0.0",
  "description": "Context-mode post-tool-use hook for context window protection",
  "when": {
    "type": "postToolUse",
    "toolTypes": ["*"]
  },
  "then": {
    "type": "runCommand",
    "command": "context-mode hook kiro posttooluse"
  }
}
